<launch>

  <!-- 开启RGB摄像头  -->
  <include file="$(find realsense2_camera)/launch/rs_rgbd.launch" >
    <arg name="enable_pointcloud"   default="false"/>
    <arg name="align_depth"         default="false"/>
    <arg name="enable_sync"         default="false"/>
    <arg name="filters"             default=""/>
  </include>

  <!-- 开启色块跟踪节点  -->
  <node name='opencv_visual_follower' pkg="simple_follower" type="VisualFollow_px4_ctrl.py" output="screen">
    <!--  上传相关参数到参数服务器 -->
    <rosparam ns='visual_angle'>
      vertical :   46.7
      horizontal : 60
    </rosparam>
    <rosparam ns='velocity_multiple'>
      forward:    0.6
      forward_kd: 0.02
      turn:       1.2
      turn_kd:    0.02
    </rosparam>
    <rosparam ns='velocity_restrict'>
      forward:   0.4
      turn:      2
    </rosparam>
    <rosparam ns='targetred'>
      upper : [118, 110, 16]
      lower : [180, 255,255]
      </rosparam>
    <rosparam ns='targetblue'>
      upper : [10,110, 120]
      lower : [110,255, 255]
      </rosparam>
    <rosparam ns='targetgreen'>
      upper : [30,30, 60]
      lower : [90,255,255]
      </rosparam>
    <rosparam ns='targetyellow'>
      upper : [80, 20,120]
      lower : [110, 255, 255]
      </rosparam>
    <param name='targetDistance' value='600' type='double' />

  </node>
  
  <!-- px4控制节点-->
  <node name='landing_node' pkg="simple_follower" type="px4_control" output="screen" />
  <!-- 开启机器人底层相关节点  -->
  <include file="$(find robot_bringup)/launch/px4.launch" />
   
</launch>

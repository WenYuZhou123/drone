<launch>

    <!--发布静态坐标转换节点，绑定了T265摄像头坐标系和雷达坐标系laser的相对位置关系 -->
    <node pkg="tf" type="static_transform_publisher"  name="t265_camera_link_to_laser" args="0 0 0.05 3.14 0 0 camera_link laser 100" />
    
    <!--发布静态坐标转换节点，绑定了T265摄像头坐标系和无人机机体坐标系base_link的相对位置关系 -->
    <node pkg="tf" type="static_transform_publisher"  name="t265_camera_link_to_base_link"  args="0 0 0 0 0 0 camera_link base_link 100" />  
    	
	<!--启动mavros节点 -->
    <include file="$(find robot_bringup)/launch/px4.launch" />

	<!--启动T265节点 -->
    <include file="$(find robot_bringup)/launch/demo_t265.launch" />

	<!--启动坐标转换节点 -->
    <include file="$(find vision_to_mavros)/launch/t265_tf_to_mavros.launch" />
   
    <!--启动镭神N10激光雷达 -->
    <include file="$(find robot_bringup)/launch/lsn10.launch" />
  
    <!-- 启动cartographer建图节点 -->
    <include file="$(find robot_bringup)/launch/cartographer_ros/demo_revo_lds_t265.launch" />

</launch>

<?xml version="1.0" encoding="utf-8"?>
<launch>
  <!-- Load Parameter -->
  <param name="use_cpu" value="false" />

  <!-- Start yolov8 and ros wrapper -->
  <node pkg="yolov8_ros" type="yolo_v8.py" name="yolov8_ros" output="screen">
    <!-- Uncomment the desired weight path -->
    <!-- <param name="weight_path" value="$(find yolov8_ros)/weights/SeaDroneSee__N.pt"/> -->
    <!-- <param name="weight_path" value="$(find yolov8_ros)/weights/SeaDroneSee_S.pt"/> -->
    <!-- <param name="weight_path" value="$(find yolov8_ros)/weights/yolov8m.pt"/> -->
    <!-- <param name="weight_path" value="$(find yolov8_ros)/weights/best.pt"/> -->
    <param name="weight_path" value="$(find yolov8_ros)/weights/ring.pt"/>

    <param name="image_topic" value="/d435/color/image_raw" />
    <param name="pub_topic" value="/yolov8/BoundingBoxes" />
    <!-- <param name="camera_frame" value="d435_link"/> -->
    <param name="visualize" value="false" />
    <param name="conf" value="0.75" />
  </node>
</launch>


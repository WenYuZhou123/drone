
<launch>    
    <param name="linear_x_p" value="0.6"/>
    <param name="linear_x_d" value="0.5"/>
  
    <param name="yaw_rate_p" value="0.8"/>
    <param name="yaw_rate_d" value="1.0"/>
    
    <param name="target_x_angle"  value="0"/>
    <param name="target_distance" value="2000"/>
    
    <param name="x_angle_threshold" value="0.02"/>
    <param name="distance_threshold" value="100"/>
   
    <param name="max_raw_velocity_x" value="2"/>
    <param name="max_raw_yaw_rate" value="1.0"/>     
    
  <node pkg="target_follow" type="target_follow_horizontal" name="target_follow_horizontal" output="screen"/>
</launch>
